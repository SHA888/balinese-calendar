---
import DocsLayout from '../../layouts/DocsLayout.astro';
---

<DocsLayout title="Quick Start - Balinese Calendar" description="Quick start guide">
	<h1 class="font-display text-4xl gold-accent mb-8">Quick Start</h1>

	<div class="code-block mb-6">
		<pre><code class="language-rust">use balinese_calendar::BalineseDate;

let date = BalineseDate::from_ymd(2023, 1, 1)?;</code></pre>
	</div>

	<div class="code-block mb-6">
		<pre><code class="language-rust">println!("Saka Year: {}", date.saka_year());
println!("Sasih: {}", date.sasih_name());</code></pre>
	</div>
</DocsLayout>
