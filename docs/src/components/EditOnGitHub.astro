---
// Edit on GitHub component
interface Props {
	url: string;
}

const { url }: Props = Astro.props;
---

<a
	href={url}
	target="_blank"
	rel="noopener noreferrer"
	class="inline-flex items-center space-x-2 text-sm text-balinese-gold hover:text-balinese-turquoise transition-colors mb-4"
>
	<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
		<path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4.586 4.586a2 2 0 102.828 2.828l4.586-4.586a4 4 0 00-5.656-5.656l-4.586 4.586a2 2 0 00-2.828 2.828l4.586 4.586a1 1 0 001.414-1.414l-4.586-4.586a2 2 0 112.828-2.828l4.586 4.586a4 4 0 005.656 5.656l-4.586-4.586a1 1 0 00-1.265-.633zM5.707 6.293a1 1 0 00-1.414 1.414l4.586 4.586a1 1 0 001.414-1.414l-4.586-4.586z" clip-rule="evenodd" />
	</svg>
	<span>Edit this page on GitHub</span>
</a>
